{
  "name": "vite-tailwind-starter",
  "description": "NoJS Vite + Tailwind CSS Starter",
  "version": "0.0.0",
  "keywords": [
    "template",
    "scaffold",
    "tailwind",
    "tailwindcss",
    "tailwind-css",
    "vite",
    "vitejs",
    "vite-template",
    "vitejs-template",
    "vite-tailwind"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write './src/**/*.{html,css,js,jsx,ts,tsx}'",
    "format:check": "prettier --check './src/**/*.{html,css,js,jsx,ts,tsx}'"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "cssnano": "^8.0.2",
    "postcss": "^8.5.22",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5"
  }
}
